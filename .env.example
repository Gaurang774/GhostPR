# Environment Variables — GhostPR MVP
# Copy this to .env and fill in your values

# ─── GitHub ───────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name

# ─── Groq (Decision Extraction) ───────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Hindsight (Vectorize Memory) ─────────────────────
HINDSIGHT_API_KEY=your_hindsight_key_here
HINDSIGHT_BANK_URL=https://api.hindsight.vectorize.io/mcp/YOUR_BANK/

# ─── SQLite ───────────────────────────────────────────
DATABASE_PATH=./data/GhostPR.db

# ─── App ──────────────────────────────────────────────
NODE_ENV=development
DASHBOARD_PORT=3000
